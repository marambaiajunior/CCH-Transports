# Example environment configuration for CCH Logistics TMS

SECRET_KEY=your-secret-key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
TIME_ZONE=America/Denver

# Final public domain (Render URL or custom domain)
APP_DOMAIN=https://cch-transports.onrender.com

# PostgreSQL database configuration (used when DEBUG=False)
POSTGRES_DB=cchlogistics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# CSRF trusted origins (comma separated)
CSRF_TRUSTED_ORIGINS=https://cch-transports.onrender.com

# Email configuration (optional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=username
EMAIL_HOST_PASSWORD=password
DEFAULT_FROM_EMAIL=info@example.com
